{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/normancomics/Watcher_Tech-Blockchain_Grimoire/schemas/timeline.schema.json",
  "title": "GrimoireTimeline",
  "description": "Schema for timeline JSON files in corpus/timelines/",
  "type": "object",
  "required": ["id", "title", "epistemic_status", "events"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "title": {
      "type": "string"
    },
    "epistemic_status": {
      "type": "string",
      "enum": ["documented", "contested", "speculative", "fiction"]
    },
    "citations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "description": {
      "type": "string"
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["date", "title", "description"],
        "properties": {
          "date": {
            "type": "string",
            "description": "ISO 8601 date, approximate date (e.g. 'c. 3000 BCE'), or era label"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "epistemic_status": {
            "type": "string",
            "enum": ["documented", "contested", "speculative", "fiction"]
          },
          "citations": {
            "type": "array",
            "items": { "type": "string" }
          },
          "entity_refs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Entity IDs relevant to this event"
          },
          "blockchain_parallel": {
            "type": "string",
            "description": "Modern blockchain/tech event that parallels this historical event"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}
