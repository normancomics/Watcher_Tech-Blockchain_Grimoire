{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/normancomics/Watcher_Tech-Blockchain_Grimoire/schemas/faction.schema.json",
  "title": "GrimoireFaction",
  "description": "Schema for faction YAML files in corpus/factions/",
  "type": "object",
  "required": ["id", "name", "epistemic_status", "citations"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "name": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "epistemic_status": {
      "type": "string",
      "enum": ["documented", "contested", "speculative", "fiction"]
    },
    "citations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "description": {
      "type": "string"
    },
    "origin_era": {
      "type": "string",
      "description": "Historical or mythological era of origin"
    },
    "blockchain_analogue": {
      "type": "string",
      "description": "Modern blockchain ecosystem or protocol this faction maps to"
    },
    "members": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Entity IDs that are members of this faction"
    },
    "doctrines": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Core principles or practices of the faction"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}
