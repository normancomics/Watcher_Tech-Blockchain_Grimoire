# ─── Deployer ────────────────────────────────────────────────────────────────
# Private key of normancomics.eth deployer wallet (never commit a real key!)
PRIVATE_KEY=

# ─── Basescan / Etherscan ─────────────────────────────────────────────────────
BASESCAN_API_KEY=

# ─── RPC Endpoints ────────────────────────────────────────────────────────────
BASE_MAINNET_RPC=https://mainnet.base.org
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ─── x402 Payment Receiver ───────────────────────────────────────────────────
