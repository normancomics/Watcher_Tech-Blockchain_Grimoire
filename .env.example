# ⛧ Grimoire MCP — Environment Variables

# ──────────────────────────────────────────
# Required for on-chain tools
# ──────────────────────────────────────────

# RPC endpoint (Alchemy, Infura, QuickNode, etc.)
WEB3_PROVIDER_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Sovereign agent wallet private key (write operations only)
# WARNING: never commit this value to source control
AGENT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# ──────────────────────────────────────────
# Contract addresses (set after deployment)
# ──────────────────────────────────────────

# Deployed GrimoireAccessPass.sol (ERC-1155 monetization)
ACCESS_PASS_ADDRESS=

# Deployed OccultKnowledgeAccess.sol
KNOWLEDGE_ACCESS_ADDRESS=
