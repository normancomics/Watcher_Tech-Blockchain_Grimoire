RECEIVER_WALLET=

# ─── Deployed Contract Addresses (fill after running Deploy.s.sol) ────────────
SIGIL_NFT_ADDRESS=
ARCANUS_MATHEMATICA_ADDRESS=
SPELL_PAYMENT_ADDRESS=
WATCHER_GATE_ADDRESS=
ERC8004_REGISTRY_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=
